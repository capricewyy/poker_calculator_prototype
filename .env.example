# Poker Night — environment template. SAFE TO COMMIT (placeholders only).
# Copy to .env (git-ignored) and fill the <...> values from the Supabase
# dashboard (Settings → API) and your password manager.

# ─────────────────────────────────────────────────────────────
# Shared / CI
# ─────────────────────────────────────────────────────────────
# Personal access token for the Supabase CLI (Account → Access Tokens). Used by CI + local pushes.
SUPABASE_ACCESS_TOKEN=<supabase-personal-access-token>

# ─────────────────────────────────────────────────────────────
# Local dev (supabase start — values printed by `supabase start`)
# ─────────────────────────────────────────────────────────────
LOCAL_SUPABASE_URL=http://127.0.0.1:54321
LOCAL_SUPABASE_ANON_KEY=<local-anon-key-from-supabase-start>
LOCAL_SUPABASE_SERVICE_ROLE_KEY=<local-service-role-key-from-supabase-start>
LOCAL_SUPABASE_JWT_SECRET=<local-jwt-secret-from-supabase-start>

# ─────────────────────────────────────────────────────────────
# Staging — project ref ejxgpmutndhdsmquasaa
# ─────────────────────────────────────────────────────────────
STAGING_SUPABASE_PROJECT_REF=ejxgpmutndhdsmquasaa
STAGING_SUPABASE_URL=https://ejxgpmutndhdsmquasaa.supabase.co
STAGING_SUPABASE_ANON_KEY=<staging-anon-key>
STAGING_SUPABASE_SERVICE_ROLE_KEY=<staging-service-role-key>
STAGING_SUPABASE_JWT_SECRET=<staging-jwt-secret>
STAGING_SUPABASE_DB_PASSWORD=<staging-db-password>

# ─────────────────────────────────────────────────────────────
# Prod — project ref kdzdddwtqmyrouyjoqud
# ─────────────────────────────────────────────────────────────
PROD_SUPABASE_PROJECT_REF=kdzdddwtqmyrouyjoqud
PROD_SUPABASE_URL=https://kdzdddwtqmyrouyjoqud.supabase.co
PROD_SUPABASE_ANON_KEY=<prod-anon-key>
PROD_SUPABASE_SERVICE_ROLE_KEY=<prod-service-role-key>
PROD_SUPABASE_JWT_SECRET=<prod-jwt-secret>
PROD_SUPABASE_DB_PASSWORD=<prod-db-password>

# ─────────────────────────────────────────────────────────────
# OAuth providers — Google (Web client; redirect URI = Supabase /auth/v1/callback)
# ─────────────────────────────────────────────────────────────
STAGING_GOOGLE_OAUTH_CLIENT_ID=<staging-google-client-id>
STAGING_GOOGLE_OAUTH_CLIENT_SECRET=<staging-google-client-secret>
PROD_GOOGLE_OAUTH_CLIENT_ID=<prod-google-client-id>
PROD_GOOGLE_OAUTH_CLIENT_SECRET=<prod-google-client-secret>

# ─────────────────────────────────────────────────────────────
# OAuth providers — Apple (deferred until staging launch; needs Apple Developer enrollment)
# ─────────────────────────────────────────────────────────────
STAGING_APPLE_SERVICE_ID=<staging-apple-service-id>
STAGING_APPLE_SECRET_KEY=<staging-apple-generated-jwt-secret>
PROD_APPLE_SERVICE_ID=<prod-apple-service-id>
PROD_APPLE_SECRET_KEY=<prod-apple-generated-jwt-secret>
